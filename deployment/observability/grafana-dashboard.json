          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "id": 103,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "text": {} },
      "targets": [
        {
          "expr": "sum(rate({component=\"api-gateway\"} | json | statusCode >= 400 [$__auto])) / sum(rate({component=\"api-gateway\"} | json [$__auto])) * 100",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ],
      "title": "Error Rate %",
      "type": "stat"
