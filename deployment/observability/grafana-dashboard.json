        "expr": "{component=~\"circuit-breaker|twoDProcessor|threeDProcessor\", level=\"warn\"} | json | msg=~\"state change|circuit open\"",
        "hide": false,
        "iconColor": "red",
        "name": "Circuit Breaker Events",
        "tagKeys": "component,msg",
        "textFormat": "CB {{msg}}",
        "titleFormat": "{{component}}"
      }
